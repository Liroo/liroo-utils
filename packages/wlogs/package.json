{
  "name": "@liroo/wlogs",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": { "types": "./dist/client/wcl-client.d.ts", "import": "./dist/client/wcl-client.js" },
    "./analysis/event-fetcher": { "types": "./dist/analysis/event-fetcher.d.ts", "import": "./dist/analysis/event-fetcher.js" },
    "./analysis/echo": { "types": "./dist/analysis/modules/echo-analysis.d.ts", "import": "./dist/analysis/modules/echo-analysis.js" },
    "./analysis/essence-burst": { "types": "./dist/analysis/modules/essence-burst-analysis.d.ts", "import": "./dist/analysis/modules/essence-burst-analysis.js" },
    "./analysis/cast-efficiency": { "types": "./dist/analysis/modules/cast-efficiency.d.ts", "import": "./dist/analysis/modules/cast-efficiency.js" },
    "./analysis/essence-timeline": { "types": "./dist/analysis/modules/essence-timeline.d.ts", "import": "./dist/analysis/modules/essence-timeline.js" },
    "./constants": { "types": "./dist/constants/spells.d.ts", "import": "./dist/constants/spells.js" },
    "./types": { "types": "./dist/types/wcl-responses.d.ts", "import": "./dist/types/wcl-responses.js" }
  },
  "typesVersions": {
    "*": {
      "client": ["dist/client/wcl-client.d.ts"],
      "analysis/event-fetcher": ["dist/analysis/event-fetcher.d.ts"],
      "analysis/echo": ["dist/analysis/modules/echo-analysis.d.ts"],
      "analysis/essence-burst": ["dist/analysis/modules/essence-burst-analysis.d.ts"],
      "analysis/cast-efficiency": ["dist/analysis/modules/cast-efficiency.d.ts"],
      "analysis/essence-timeline": ["dist/analysis/modules/essence-timeline.d.ts"],
      "constants": ["dist/constants/spells.d.ts"],
      "types": ["dist/types/wcl-responses.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.8.0"
  }
}
